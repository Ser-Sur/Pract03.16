<Window x:Class="Pract03._16.ModelsBD.TableInteraction"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Pract03._16.ModelsBD"
        mc:Ignorable="d"
        Title="TableInteraction" x:Name="wTableInteraction" Height="520" Width="300" ResizeMode="NoResize" Loaded="TableInteraction_Loaded" Icon="/ModelsBD/МАХ.png">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Content="Пункт назначения" HorizontalAlignment="Center" VerticalAlignment="Bottom" Height="25" Margin="0,0,0,5"/>
        <Label Grid.Row="2" Content="Время вылета" HorizontalAlignment="Center" VerticalAlignment="Bottom" Height="25" Margin="0,0,0,5"/>
        <Label Grid.Row="4" Content="Время прибытия" HorizontalAlignment="Center" VerticalAlignment="Bottom" Height="25" Margin="0,0,0,5"/>
        <Label Grid.Row="6" Content="Кол-во свободных мест" HorizontalAlignment="Center" VerticalAlignment="Bottom" Height="25" Margin="0,0,0,5"/>
        <Label Grid.Row="8" Content="Тип самолета" HorizontalAlignment="Center" VerticalAlignment="Bottom" Height="25" Margin="0,0,0,5"/>
        <Label Grid.Row="10" Content="Кол-во посадочных мест" HorizontalAlignment="Center" VerticalAlignment="Bottom" Height="25" Margin="0,0,0,5"/>
        <TextBox Grid.Row="1" x:Name="tbDestination" Text="{Binding Path=Destination}" HorizontalAlignment="Center" VerticalAlignment="Bottom" Height="30" Width="200" Margin="0,0,0,5"/>
        <TextBox Grid.Row="3" x:Name="tbDepartureTime" Text="{Binding Path=DepartureTime}" HorizontalAlignment="Center" VerticalAlignment="Bottom" Height="30" Width="200" Margin="0,0,0,5"/>
        <TextBox Grid.Row="5" x:Name="tbArrivalTime" Text="{Binding Path=ArrivalTime}" HorizontalAlignment="Center" VerticalAlignment="Bottom" Height="30" Width="200" Margin="0,0,0,5"/>
        <TextBox Grid.Row="7" x:Name="tbCountFreePlaces" Text="{Binding Path=CountFreePlaces}" HorizontalAlignment="Center" VerticalAlignment="Bottom" Height="30" Width="200" Margin="0,0,0,5"/>
        <TextBox Grid.Row="9" x:Name="tbTypePlane" Text="{Binding Path=TypePlane}" HorizontalAlignment="Center" VerticalAlignment="Bottom" Height="30" Width="200" Margin="0,0,0,5"/>
        <TextBox Grid.Row="11" x:Name="tbCapacity" Text="{Binding Path=Capacity}" HorizontalAlignment="Center" VerticalAlignment="Bottom" Height="30" Width="200" Margin="0,0,0,5"/>
        <Button x:Name="btnAddEditTI" Content="Добавить" Width="110" Height="30" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="25,0,0,0" Grid.Row="12" Click="AddEditTI_Click"/>
        <Button x:Name="btnCancel" Content="Отмена" Width="110" Height="30" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Row="12" Click="CancelTi_Click" Margin="0,0,25,0"/>
    </Grid>
</Window>
