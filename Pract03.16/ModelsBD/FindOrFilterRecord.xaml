<Window x:Class="Pract03._16.ModelsBD.FindOrFilterRecord"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Pract03._16.ModelsBD"
        mc:Ignorable="d"
        x:Name="wFindOrFilter" Title="FindOrFilterRecord" Height="150" Width="200" ResizeMode="NoResize">
    <Grid >
        <Grid.RowDefinitions >
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions >
        <TextBox x:Name = "tbCriterion" Margin = "25,10,25,10" />
        <Button Grid.Row = "1" x:Name = "btnFind" Click = "Find_Click" Content = "Поиск" FontSize = "20" Margin = "25,10,25,10" />
    </Grid >
</Window>
